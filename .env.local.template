# ============================================
# FIREBASE ADMIN (SERVER ONLY) — Service Account
# ASLA bu dosyayı paylaşmayın veya git'e commit etmeyin.
# Alış yeri: Firebase Console > Project Settings > Service Accounts
#            > Generate new private key (JSON indirilir)
#
# JSON içindeki alanlar:
#   project_id      -> FIREBASE_ADMIN_PROJECT_ID
#   client_email    -> FIREBASE_ADMIN_CLIENT_EMAIL
#   private_key     -> FIREBASE_ADMIN_PRIVATE_KEY (tırnak içinde, \n'leri olduğu gibi bırakın)
# ============================================
FIREBASE_ADMIN_PROJECT_ID=ihalepilotu-59f74
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=""

# ============================================
# SESSION
# ============================================
SESSION_COOKIE_NAME=ihale_pilotu_session
