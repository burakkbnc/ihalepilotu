# ============================================
# FIREBASE CLIENT (PUBLIC) — Next.js public env vars
# Firebase Console > Project Settings > General > Your apps > SDK config
# ============================================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# OPSİYONEL (Faz 1): Cloud Storage Billing gerektirir. Faz 1'de boş bırakılabilir;
# Storage'a bağımlı özellikler otomatik olarak devre dışı kalır (bkz. STORAGE_ENABLED).
# Faz 2'de Storage etkinleştirildiğinde buraya bucket adı eklenmelidir.
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ============================================
# FIREBASE ADMIN (SERVER ONLY) — Service Account
# Firebase Console > Project Settings > Service Accounts > Generate new private key
# IMPORTANT: FIREBASE_PRIVATE_KEY must keep \n characters escaped (single line)
# ============================================
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----\n"

# ============================================
# SESSION
# ============================================
SESSION_COOKIE_NAME=ihale_pilotu_session
# Session cookie lifetime in milliseconds (default 5 days)
SESSION_COOKIE_EXPIRES_MS=432000000

# ============================================
# LLM PROVIDERS (Faz 3 — parser pipeline AI özet katmanı)
#
# LLM_PROVIDER seçenekleri: mock | anthropic | openai | gemini
# Faz 3 itibarıyla 'anthropic' | 'openai' | 'gemini' seçilse de
# bu provider'lar henüz tamamlanmadığı (placeholder) için sistem
# otomatik olarak MockLLMProvider'a düşer (console.warn ile loglanır).
# Gerçek bir API çağrısı yapılması için Faz 4'te ilgili provider
# tamamlanmalıdır. Varsayılan: mock (API anahtarı gerektirmez).
# ============================================
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ============================================
# OCR PROVIDER (Faz 6 — ücretsiz Tesseract OCR fallback)
# PDF içinde seçilebilir metin yoksa sistem Tesseract ile OCR dener.
# TESSERACT_LANG: Türkçe + İngilizce için varsayılan tur+eng.
# TESSERACT_MAX_PDF_PAGES: İlk sürümde maliyet/süre kontrolü için sayfa limiti.
# ============================================
TESSERACT_LANG=tur+eng
TESSERACT_MAX_PDF_PAGES=15
TESSERACT_PDF_SCALE=1.8

# Virgülle ayırarak platform super admin e-postalarını tanımlayın.
# Örn: SUPER_ADMIN_EMAILS=admin@ihalepilotu.com,burakk.bnc@gmail.com
SUPER_ADMIN_EMAILS=
